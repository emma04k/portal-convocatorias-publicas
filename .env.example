# Development database URL used inside Docker Compose.
# The hostname is the Compose service name `db`, not localhost.
DATABASE_URL="postgresql://postgres:<POSTGRES_PASSWORD>@db:5432/portal_convocatorias?schema=public"

# Development-only PostgreSQL password used by Docker Compose.
POSTGRES_PASSWORD="<set-local-dev-password>"

# Replace in local .env with a strong secret before implementing auth.
JWT_SECRET="change-me-in-local-env"
